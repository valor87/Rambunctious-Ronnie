  m_Name: LeadRole
  m_EditorClassIdentifier: 
  questionText: How would you fare if you were the main role? Main source of attention?
  traitsRevealed:
  - {fileID: 11400000, guid: a5e031b4b8ad96643858c00f5b5b1358, type: 2}
